## ─── 必填 ─────────────────────────────────────────────────────────
# 首次启动 bootstrap 用 — 之后可在设置页改密码,改了以后这个 env 就失效
APP_PASSWORD=changeme

## ─── 可选 ─────────────────────────────────────────────────────────

# 数据库 URL — 留空 = sqlite:///$DATA_DIR/autofree.db
# DATABASE_URL=sqlite:////app/data/autofree.db
# DATABASE_URL=postgresql+psycopg://autofree:changeme@db:5432/autofree
# DATABASE_URL=mysql+pymysql://user:pass@host:3306/autofree

# Session 签名 secret — 不填启动时随机生成 + 持久化
SESSION_SECRET=

# 数据 / 输出 / 截图 都放这下面(SQLite + JSON 输出 + screenshots)
DATA_DIR=/app/data

# Playwright 是否无头 — Cloudflare turnstile 会抓 headless,默认 false。
# 容器内通过 xvfb-run 提供虚拟 X server,无需真桌面。
FREEGEN_HEADLESS=false

## ─── 业务配置(cloud-mail / SMS / CPA / 域名池)请到 web 设置页配 ────
##  这里不出现 cloud-mail / 5sim / hero-sms / CPA URL 等,刻意避免双数据源。
